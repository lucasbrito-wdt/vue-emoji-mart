{
  "name": "@luquinhasbrito/emoji-mart-data",
  "version": "0.1.0",
  "description": "Data for Vue Emoji Mart; emoji picker data for Vue 3",
  "license": "MIT",
  "homepage": "https://github.com/lucasbrito-wdt/vue-emoji-mart/tree/main/packages/data#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasbrito-wdt/vue-emoji-mart.git",
    "directory": "packages/data"
  },
  "bugs": {
    "url": "https://github.com/lucasbrito-wdt/vue-emoji-mart/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "sets/15/native.json",
  "types": "index.d.ts",
  "sideEffects": false,
  "scripts": {
    "regen": "node ./build.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./sets/15/native.json",
      "default": "./sets/15/native.json"
    },
    "./sets/*": "./sets/*",
    "./i18n/*": "./i18n/*"
  },
  "files": [
    "/i18n",
    "/sets",
    "index.d.ts",
    "LICENSE"
  ]
}
